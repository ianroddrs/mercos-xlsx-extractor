{
  "manifest_version": 3,
  "name": "Exportar Pedido Mercos",
  "version": "1.0.0",
  "description": "Exporta SKUs e quantidades do pedido para um ficheiro Excel.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "icons": {
    "16": "src/img/icon_active.png",
    "48": "src/img/icon_active.png",
    "128": "src/img/icon_active.png"
  },
  "action": {
    "default_popup": "src/templates/popup.html",
    "default_icon": "src/img/icon_inactive.png"
  },
  "host_permissions": [
    "https://app.mercos.com/*"
  ],
  "background": {
    "service_worker": "src/js/background.js"
  }
}